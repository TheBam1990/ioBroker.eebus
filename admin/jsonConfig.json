{
  "type": "tabs",
  "i18n": true,
  "items": {
    "main": {
      "type": "panel",
      "label": "General",
      "items": {
        "enabled": {
          "type": "checkbox",
          "label": "Enable adapter",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "shipEnabled": {
          "type": "checkbox",
          "label": "Enable SHIP listener and peer check",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "deviceBrand": {
          "type": "text",
          "label": "Device brand",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "deviceModel": {
          "type": "text",
          "label": "Device model",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "deviceType": {
          "type": "select",
          "label": "EEbus device type",
          "options": [
            {
              "label": "EnergyManagementSystem",
              "value": "EnergyManagementSystem"
            },
            {
              "label": "ChargingStation",
              "value": "ChargingStation"
            },
            {
              "label": "Battery",
              "value": "Battery"
            },
            {
              "label": "HeatPump",
              "value": "HeatPump"
            },
            {
              "label": "PVInverter",
              "value": "PVInverter"
            }
          ],
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "deviceSerial": {
          "type": "text",
          "label": "Device serial",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "pollIntervalMs": {
          "type": "number",
          "label": "Diagnostic interval ms",
          "min": 5000,
          "max": 3600000,
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        }
      }
    },
    "ship": {
      "type": "panel",
      "label": "SHIP",
      "items": {
        "shipBind": {
          "type": "text",
          "label": "Local bind address",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "shipPort": {
          "type": "number",
          "label": "Local SHIP port",
          "help": "EEbus SHIP commonly uses TCP/TLS port 4712.",
          "min": 1,
          "max": 65535,
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "peerHost": {
          "type": "text",
          "label": "Peer host",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "peerPort": {
          "type": "number",
          "label": "Peer SHIP port",
          "min": 1,
          "max": 65535,
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "connectTimeoutMs": {
          "type": "number",
          "label": "Connect timeout ms",
          "min": 1000,
          "max": 120000,
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "expectedPeerSki": {
          "type": "text",
          "label": "Expected peer SKI",
          "help": "Optional SHA-1 subject key identifier/fingerprint check for the peer certificate.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    },
    "certificate": {
      "type": "panel",
      "label": "Certificate",
      "items": {
        "autoGenerateCertificate": {
          "type": "checkbox",
          "label": "Generate local self-signed certificate if empty",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "certificatePem": {
          "type": "text",
          "label": "Certificate PEM",
          "minRows": 6,
          "maxRows": 12,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "certificateFile": {
          "type": "fileSelector",
          "label": "Certificate file (upload/download)",
          "help": "Upload a PEM/CRT/CER certificate. The uploaded file takes precedence over the manually entered PEM text.",
          "objectID": "eebus.%INSTANCE%.certificates",
          "pattern": "*.*",
          "upload": "/",
          "refresh": true,
          "noSize": false,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "privateKeyPem": {
          "type": "text",
          "label": "Private key PEM",
          "minRows": 6,
          "maxRows": 12,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "privateKeyFile": {
          "type": "fileSelector",
          "label": "Private key file (upload/download)",
          "help": "Upload or select the matching unencrypted PEM/KEY private key. Protect downloads of this sensitive file.",
          "objectID": "eebus.%INSTANCE%.certificates",
          "pattern": "*.*",
          "upload": "/",
          "refresh": true,
          "noSize": false,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    },
    "advanced": {
      "type": "panel",
      "label": "Advanced",
      "items": {
        "mdnsEnabled": {
          "type": "checkbox",
          "label": "Prepare mDNS discovery states",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "spineEnabled": {
          "type": "checkbox",
          "label": "Enable SPINE placeholder states",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        }
      }
    }
  }
}
